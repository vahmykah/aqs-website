---
interface Props {
  isHomepage?: boolean;
  name: string;
  price: string;
  id: string;
}

const { isHomepage = false, name, price, id } = Astro.props;

// Convert formatted price string to numeric value for cart math (e.g., "IDR 305.000" -> 305000)
const numericPrice = parseInt(price.replace(/[^0-9]/g, ''), 10) || 0;
---

<section class="product-info-section">
  <div class="info-container">
    <div class="product-meta">
      <h1 class="product-title">{name}</h1>
      <span class="product-price">{price}</span>
    </div>

    <!-- Solid white Add to Cart button - displayed exclusively on product details page -->
    {!isHomepage && (
      <button 
        class="add-to-cart-button" 
        data-product-id={id} 
        data-product-name={name} 
        data-product-price={numericPrice}
      >
        ADD TO CART
      </button>
    )}
  </div>
</section>

<style>
  .product-info-section {
    padding: var(--spacing-lg) 0;
    background-color: var(--color-bg);
    display: flex;
    justify-content: center;
    align-items: center;
    text-align: center;
  }

  .info-container {
    max-width: 600px;
    padding: 0 var(--spacing-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .product-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .product-title {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .product-price {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-text-primary);
    margin-top: 0.25rem;
  }

  .add-to-cart-button {
    background-color: var(--color-button-bg); /* Solid white */
    color: var(--color-button-text); /* Solid dark */
    padding: 1.15rem 4rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    transition: opacity 0.2s ease;
    border-radius: 0;
    width: 100%;
    max-width: 320px;
    margin-top: 0.5rem;
  }

  .add-to-cart-button:hover {
    opacity: 0.9;
  }

  .details-link {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    transition: color 0.2s ease;
    margin-top: 0.5rem;
  }

  .details-link:hover {
    color: var(--color-text-primary);
  }

  @media (max-width: 767px) {
    .product-info-section {
      padding: var(--spacing-md) 0;
    }
  }
</style>

<script>
  document.querySelectorAll('.add-to-cart-button').forEach(btn => {
    btn.addEventListener('click', (ev) => {
      const target = ev.currentTarget as HTMLElement;
      const id = target.getAttribute('data-product-id') || '';
      const name = target.getAttribute('data-product-name') || '';
      const price = parseInt(target.getAttribute('data-product-price') || '0', 10);
      
      if ((window as any).AQS_Cart) {
        (window as any).AQS_Cart.addItem({
          id,
          name,
          price,
          image: id === 'soe-bag-2' ? '/images/bag-2-front.jpg' : '/images/front.jpg'
        });
      }
    });
  });
</script>
