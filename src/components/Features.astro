---
interface Props {
  features?: string[];
  designDetails?: string[];
}

const defaultFeatures = [
  "3-Way Carry System",
  "Laptop Compartment",
  "Bottle Holder",
  "2 Utility Pockets",
  "Large Zipper Pocket",
  "2 Premium Nylon Straps"
];

const defaultDesignDetails = [
  "Premium Canvas Construction",
  "High Density Arabic Typography",
  "Monochrome Editorial Design"
];

const { 
  features = defaultFeatures, 
  designDetails = defaultDesignDetails 
} = Astro.props;
---

<section class="features-details-section">
  <div class="section-container">
    <div class="editorial-grid">
      <!-- Section 1: Features (Functionality) -->
      <div class="editorial-column">
        <h2 class="column-title">FEATURES</h2>
        <ul class="editorial-list">
          {features.map((item) => (
            <li class="list-item">{item}</li>
          ))}
        </ul>
      </div>

      <div class="editorial-divider" aria-hidden="true"></div>

      <!-- Section 2: Design Details (Craftsmanship & Aesthetic) -->
      <div class="editorial-column">
        <h2 class="column-title">DESIGN DETAILS</h2>
        <ul class="editorial-list">
          {designDetails.map((item) => (
            <li class="list-item">{item}</li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .features-details-section {
    padding: var(--spacing-lg) 0;
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .section-container {
    max-width: 1000px; /* Centered, slightly narrow to feel intimate and editorial */
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .editorial-grid {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 4rem;
  }

  .editorial-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-family: var(--font-sans);
  }

  .column-title {
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-primary);
    text-transform: uppercase;
  }

  .editorial-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .list-item {
    font-size: var(--text-sm);
    line-height: 1.5;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
  }

  .editorial-divider {
    width: 1px;
    align-self: stretch;
    background-color: var(--color-border);
  }

  @media (max-width: 767px) {
    .features-details-section {
      padding: var(--spacing-md) 0;
    }

    .editorial-grid {
      flex-direction: column; /* Stack vertically on mobile screen devices */
      gap: 3rem;
    }

    .editorial-divider {
      width: 100%;
      height: 1px;
    }
  }
</style>
