---
interface ImageItem {
  src: string;
  alt: string;
}

interface Props {
  images?: ImageItem[];
}

// Default fallback sequence (Bag 1 details)
const defaultImages = [
  { src: '/images/hero-editorial.jpg', alt: 'Hero Editorial Shot' },
  { src: '/images/front.jpg', alt: 'Front View' },
  { src: '/images/tote.jpg', alt: 'Tote Mode' },
  { src: '/images/sling.jpg', alt: 'Sling Mode' },
  { src: '/images/backpack.jpg', alt: 'Backpack Mode' },
  { src: '/images/interior.jpg', alt: 'Open Interior View' },
  { src: '/images/laptop.jpg', alt: 'Laptop Compartment Detail' },
  { src: '/images/bottle.jpg', alt: 'Bottle Holder Detail' },
  { src: '/images/zipper.jpg', alt: 'Large Zipper Pocket Detail' },
  { src: '/images/texture.jpg', alt: 'Material & Texture Detail' }
];

const { images = defaultImages } = Astro.props;
---

<section class="gallery-section">
  <div class="gallery-container">
    <div class="gallery-grid">
      {images.map((img, idx) => (
        <div class="gallery-item-wrap">
          <button class="gallery-btn" aria-label={`View larger image ${idx + 1}`} data-src={img.src} data-alt={img.alt}>
            <img 
              src={img.src} 
              alt={img.alt} 
              class="gallery-image" 
              width="800" 
              height="1000" 
              loading="lazy" 
              decoding="async"
            />
          </button>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Lightbox Modal for Premium Image Inspecting -->
<dialog id="gallery-lightbox" class="lightbox-dialog">
  <div class="lightbox-content">
    <button id="lightbox-close-btn" class="lightbox-close" aria-label="Close Lightbox">CLOSE</button>
    <img id="lightbox-img" src="" alt="" class="lightbox-img" />
    <p id="lightbox-caption" class="lightbox-caption"></p>
  </div>
</dialog>

<style>
  .gallery-section {
    padding: var(--spacing-lg) 0;
    background-color: var(--color-bg);
  }

  .gallery-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  /* Flexible auto-fitting grid that supports fewer or additional assets */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 3rem;
  }

  .gallery-item-wrap {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .gallery-btn {
    width: 100%;
    display: block;
    aspect-ratio: 4 / 5;
    background-color: #242424; /* Dark loader placeholder */
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: opacity 0.3s ease;
  }

  .gallery-btn:hover {
    opacity: 0.95;
  }

  .gallery-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .gallery-btn:hover .gallery-image {
    transform: scale(1.02);
  }

  /* Lightbox Styles */
  .lightbox-dialog {
    border: none;
    background: transparent;
    padding: 0;
    margin: 0;
    width: 100vw;
    height: 100vh;
    max-width: 100%;
    max-height: 100%;
    position: fixed;
    top: 0;
    left: 0;
    z-index: 2000;
  }

  .lightbox-dialog::backdrop {
    background-color: rgba(17, 17, 17, 0.98); /* Matte black backdrop for dark theme */
    backdrop-filter: blur(12px);
  }

  .lightbox-content {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 3rem;
    position: relative;
  }

  .lightbox-close {
    position: absolute;
    top: 2rem;
    right: 2rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    transition: opacity 0.2s ease;
  }

  .lightbox-close:hover {
    opacity: 0.6;
  }

  .lightbox-img {
    max-width: 80%;
    max-height: 80%;
    object-fit: contain;
    border: 1px solid var(--color-border);
  }

  .lightbox-caption {
    margin-top: 1.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
  }

  @media (max-width: 767px) {
    .gallery-section {
      padding: var(--spacing-md) 0;
    }

    .gallery-container {
      padding: 0 1.25rem;
    }

    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .lightbox-content {
      padding: 1.5rem;
    }

    .lightbox-img {
      max-width: 95%;
      max-height: 75%;
    }
  }
</style>

<script>
  const lightbox = document.getElementById('gallery-lightbox') as HTMLDialogElement | null;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxCaption = document.getElementById('lightbox-caption');
  const closeBtn = document.getElementById('lightbox-close-btn');

  if (lightbox && lightboxImg && lightboxCaption && closeBtn) {
    document.querySelectorAll('.gallery-btn').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const target = e.currentTarget as HTMLElement;
        const src = target.getAttribute('data-src') || '';
        const alt = target.getAttribute('data-alt') || '';
        
        lightboxImg.src = src;
        lightboxImg.alt = alt;
        lightboxCaption.textContent = alt;
        lightbox.showModal();
        
        document.body.style.overflow = 'hidden';
      });
    });

    const closeLightbox = () => {
      lightbox.close();
      document.body.style.overflow = '';
    };

    closeBtn.addEventListener('click', closeLightbox);
    
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox) {
        closeLightbox();
      }
    });
  }
</script>
