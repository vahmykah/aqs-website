---
---
<div id="cart-confirm-modal" class="cart-confirm-modal-overlay hidden">
  <div class="cart-confirm-modal-container">
    <!-- Close Button -->
    <button id="cart-confirm-close" class="cart-confirm-close-btn" aria-label="Close modal">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
        <path d="M18 6L6 18M6 6l12 12"></path>
      </svg>
    </button>

    <!-- Header -->
    <h2 class="modal-header">Product Added To Cart</h2>

    <!-- Landscape Row Grid -->
    <div class="modal-landscape-grid">
      <!-- Left Column: Product Image -->
      <div class="modal-image-col">
        <img id="modal-product-img" src="/images/front.jpg" alt="" class="modal-product-image" />
      </div>

      <!-- Center Column: Product Info -->
      <div class="modal-info-col">
        <span id="modal-product-name" class="modal-product-name">SOE BAG 1</span>
        <span id="modal-product-price" class="modal-product-price">IDR 305.000</span>
        <span class="modal-product-qty">Quantity: <span id="modal-qty-val">1</span></span>
      </div>

      <!-- Right Column: Action Buttons stacked vertically -->
      <div class="modal-actions-col">
        <button id="modal-action-view-cart" class="btn-modal-primary">VIEW CART</button>
        <button id="modal-action-buy-it-now" class="btn-modal-secondary">BUY IT NOW</button>
      </div>
    </div>
  </div>
</div>

<style>
  .cart-confirm-modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.8);
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
    opacity: 0;
    transition: opacity 0.25s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .cart-confirm-modal-overlay.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .cart-confirm-modal-container {
    background-color: var(--color-bg); /* Dark `#111111` */
    border: 1px solid var(--color-border);
    width: 90%;
    max-width: 650px;
    padding: 1.5rem 2rem;
    position: relative;
    transform: translateY(20px);
    transition: transform 0.25s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cart-confirm-modal-overlay.visible .cart-confirm-modal-container {
    transform: translateY(0);
  }

  .cart-confirm-close-btn {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    background: transparent;
    color: var(--color-text-secondary);
    border: none;
    cursor: pointer;
    padding: 0.25rem;
    transition: color 0.2s;
  }

  .cart-confirm-close-btn:hover {
    color: #ffffff;
  }

  .modal-header {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    color: #ffffff;
    text-transform: uppercase;
    text-align: left;
    margin: 0 0 1.25rem 0;
  }

  .modal-landscape-grid {
    display: grid;
    grid-template-columns: 110px 1fr 160px; /* 110px image, center info, 160px buttons */
    gap: 2rem;
    align-items: center;
  }

  .modal-image-col {
    width: 110px;
  }

  .modal-product-image {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    background-color: #242424;
    border: 1px solid var(--color-border);
  }

  .modal-info-col {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    align-items: flex-start;
  }

  .modal-product-name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #ffffff;
    text-transform: uppercase;
  }

  .modal-product-price {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  .modal-product-qty {
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-secondary);
    letter-spacing: 0.05em;
  }

  .modal-actions-col {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    width: 100%;
  }

  .btn-modal-primary {
    width: 100%;
    background-color: #ffffff;
    color: var(--color-bg);
    border: 1px solid #ffffff;
    padding: 0.8rem 1.25rem; /* Reduced size by ~15-20% */
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    cursor: pointer;
    text-transform: uppercase;
    border-radius: 0;
    transition: opacity 0.2s;
  }

  .btn-modal-primary:hover {
    opacity: 0.9;
  }

  .btn-modal-secondary {
    width: 100%;
    background-color: transparent;
    color: #ffffff;
    border: 1px solid #ffffff;
    padding: 0.8rem 1.25rem; /* Reduced size by ~15-20% */
    font-family: var(--font-sans);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    cursor: pointer;
    text-transform: uppercase;
    border-radius: 0;
    transition: background-color 0.2s, color 0.2s;
  }

  .btn-modal-secondary:hover {
    background-color: #ffffff;
    color: var(--color-bg);
  }

  @media (max-width: 520px) {
    .cart-confirm-modal-container {
      padding: 1.25rem 1.5rem;
    }

    .modal-landscape-grid {
      grid-template-columns: 80px 1fr;
      gap: 1rem;
    }

    .modal-image-col {
      width: 80px;
    }

    .modal-info-col {
      align-items: flex-start;
    }

    .modal-actions-col {
      grid-column: span 2;
      flex-direction: column;
      gap: 0.5rem;
    }

    .modal-header {
      margin-bottom: 1rem;
    }
  }
</style>

<script>
  const modal = document.getElementById('cart-confirm-modal');
  const closeBtn = document.getElementById('cart-confirm-close');
  const viewCartBtn = document.getElementById('modal-action-view-cart');
  const buyNowBtn = document.getElementById('modal-action-buy-it-now');
  const imgElement = document.getElementById('modal-product-img') as HTMLImageElement | null;
  const nameElement = document.getElementById('modal-product-name');
  const priceElement = document.getElementById('modal-product-price');
  const qtyElement = document.getElementById('modal-qty-val');

  function formatIDR(amount: number): string {
    if (amount === 0) return 'IDR [Price]';
    return 'IDR ' + amount.toLocaleString('id-ID').replace(/,/g, '.');
  }

  function hideModal() {
    if (modal) {
      modal.classList.remove('visible');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 300);
    }
  }

  if (closeBtn) closeBtn.addEventListener('click', hideModal);
  if (modal) {
    modal.addEventListener('click', (ev) => {
      if (ev.target === modal) {
        hideModal();
      }
    });
  }

  // ESC key to close modal on desktop
  window.addEventListener('keydown', (ev) => {
    if (ev.key === 'Escape') {
      hideModal();
    }
  });

  if (viewCartBtn) {
    viewCartBtn.addEventListener('click', () => {
      hideModal();
      if ((window as any).AQS_Cart) {
        (window as any).AQS_Cart.openCart();
      }
    });
  }

  if (buyNowBtn) {
    buyNowBtn.addEventListener('click', () => {
      hideModal();
      // Wait a bit to let the modal close, then open cart drawer and trigger checkout
      if ((window as any).AQS_Cart) {
        (window as any).AQS_Cart.openCart();
        setTimeout(() => {
          const checkoutBtn = document.getElementById('cart-checkout-button');
          if (checkoutBtn) {
            checkoutBtn.click();
          }
        }, 150);
      }
    });
  }

  // Register the global show function
  (window as any).AQS_CartModal = {
    show(item: any) {
      if (!modal) return;

      // Update basic product details
      if (imgElement) imgElement.src = item.image || '/images/front.jpg';
      if (nameElement) nameElement.textContent = item.name || '';
      if (priceElement) priceElement.textContent = formatIDR(item.price);
      if (qtyElement) qtyElement.textContent = item.quantity || '1';

      // Show the modal with a smooth animation
      modal.classList.remove('hidden');
      // RequestAnimationFrame forces layout reflow before adding opacity class
      requestAnimationFrame(() => {
        modal.classList.add('visible');
      });
    }
  };
</script>
