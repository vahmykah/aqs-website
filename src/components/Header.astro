---
---

<header class="site-header">
  <div class="header-container">
    <div class="header-left">
      <!-- Brand Logo & Tagline Stack -->
      <a href="/" class="brand-link" aria-label="A Quiet Space Home">
        <div class="brand-identity">
          <img src="/images/logo.png" alt="A Quiet Space Logo" class="brand-logo" />
          <span class="brand-tagline">carry what matters</span>
        </div>
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 100;
    background-color: rgba(17, 17, 17, 0.9);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid transparent;
    transition: background-color 0.3s ease;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1.25rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .header-left {
    display: flex;
    align-items: center;
  }

  .brand-identity {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem; /* Minimal spacing under logo */
    text-align: center;
  }

  .brand-logo {
    display: block;
    width: 145px; /* Reduced by ~27% for secondary visual elegance */
    height: auto;
    object-fit: contain;
  }

  .brand-tagline {
    font-family: var(--font-sans); /* Satoshi */
    font-size: 0.48rem; /* Reduced from 0.55rem for secondary elegance */
    font-weight: 500;
    letter-spacing: 0.22em; /* Premium letter spacing */
    text-transform: lowercase;
    color: var(--color-text-secondary);
    line-height: 1;
  }

  @media (max-width: 767px) {
    .header-container {
      padding: 1rem 1.25rem;
    }
    
    .brand-logo {
      width: 95px; /* Reduced by ~27% on mobile screen sizes */
      height: auto;
    }

    .brand-tagline {
      font-size: 0.38rem; /* Reduced from 0.4rem to match new scaling */
      text-transform: lowercase;
      letter-spacing: 0.25em;
    }
  }
</style>


