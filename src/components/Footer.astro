---

<footer class="site-footer">
  <div class="footer-container">
    <div class="footer-top">
      <div class="footer-left">
        <span class="copyright">© AQS</span>
      </div>

      <div class="footer-right">
        <a href="https://instagram.com/aquietspace.id" target="_blank" rel="noopener noreferrer" class="footer-link">Instagram</a>
        <span class="separator">|</span>
        <a href="https://wa.me/6285286152632" target="_blank" rel="noopener noreferrer" class="footer-link">Contact</a>
        <span class="separator">|</span>
        <a href="/about" class="footer-link">About</a>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-utility">
        <a href="/faq" class="footer-link">FAQ</a>
        <span class="separator">|</span>
        <a href="/shipping-policy" class="footer-link">Shipping Policy</a>
        <span class="separator">|</span>
        <a href="/returns-exchanges" class="footer-link">Return & Exchange Policy</a>
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    background-color: var(--color-bg);
    margin-top: var(--spacing-xl);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
  }

  .footer-top, .footer-bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-bottom {
    border-top: 1px solid var(--color-border);
    padding-top: 1.5rem;
  }

  .footer-right, .footer-utility {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .separator {
    color: var(--color-border);
    font-size: 0.8rem;
    user-select: none;
  }

  .footer-link {
    color: var(--color-text-secondary);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .footer-link:hover {
    color: var(--color-text-primary);
  }

  @media (max-width: 767px) {
    .footer-container {
      padding: 2.5rem 1.25rem;
      gap: 1.5rem;
    }

    .footer-top, .footer-bottom {
      flex-direction: column;
      gap: 1rem;
      text-align: center;
    }

    .footer-right, .footer-utility {
      justify-content: center;
      flex-wrap: wrap;
      gap: 0.75rem 1rem;
    }
  }
</style>
