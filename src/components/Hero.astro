---
interface Props {
  desktopSrc: string;
  mobileSrc: string;
  alt: string;
}

const { desktopSrc, mobileSrc, alt } = Astro.props;
---

<section class="hero-section">
  <div class="hero-image-wrapper">
    <!-- Render the landscape asset consistently to ensure the full composition is loaded -->
    <img src={desktopSrc} alt={alt} class="hero-img" width="1024" height="682" loading="eager" />
  </div>
</section>

<style>
  .hero-section {
    padding-top: var(--spacing-sm);
    background-color: var(--color-bg);
    width: 100%;
  }

  .hero-image-wrapper {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .hero-img {
    width: 100%;
    height: auto;
    display: block;
    background-color: #242424; /* Dark loader placeholder */
    border: 1px solid var(--color-border);
  }

  /* Desktop and tablet 16:9 structure */
  @media (min-width: 768px) {
    .hero-img {
      aspect-ratio: 16 / 9;
      object-fit: cover;
    }
  }

  /* Mobile layout: Scales proportionally to fit viewport width with zero cropping */
  @media (max-width: 767px) {
    .hero-image-wrapper {
      padding: 0; /* Bleed to edge on mobile screens */
    }
    .hero-img {
      aspect-ratio: auto;
      object-fit: contain;
    }
  }
</style>


