---
import Layout from '../layouts/Layout.astro';
import { supabase } from '../lib/supabase';

export const prerender = false;

const id = Astro.url.searchParams.get('id');

let order = null;
let errorMsg = '';

if (!id) {
  errorMsg = 'No order ID provided.';
} else {
  const { data, error } = await supabase
    .from('orders')
    .select('*')
    .eq('id', id)
    .single();

  if (error) {
    errorMsg = 'Order not found.';
  } else {
    order = data;
  }
}
---

<Layout title="Payment Instructions | A Quiet Space" noindex={true}>
  <div class="payment-wrapper">
    {errorMsg ? (
      <div class="error-state">
        <h2 class="sentient-heading">Oops!</h2>
        <p class="satoshi-text">{errorMsg}</p>
        <a href="/" class="back-link">Return to Home</a>
      </div>
    ) : (
      <div class="payment-grid">
        <!-- Left: Payment Instructions & Upload -->
        <div class="payment-main-col">
          <h1 class="payment-title sentient-heading">PAYMENT INSTRUCTIONS</h1>
          
          <div class="bank-details-card">
            <h2 class="satoshi-text bank-subtitle">Please transfer the exact amount to:</h2>
            <div class="bank-info">
              <p class="bank-name">BCA (Bank Central Asia)</p>
              <p class="account-number" id="accountNumber">8020785480</p>
              <p class="account-name">A.n. Fahmi Hakim</p>
            </div>
          </div>

          {order.payment_status === 'Paid' ? (
            <div class="success-message">
              <h3 class="sentient-heading">Payment Confirmed</h3>
              <p class="satoshi-text">Thank you! Your payment has been confirmed and we are processing your order.</p>
            </div>
          ) : (
            <div class="upload-section">
              <h2 class="section-title sentient-heading">Upload Proof of Payment</h2>
              <p class="satoshi-text upload-desc">Please upload your transfer receipt to confirm your order.</p>
              
              <form id="upload-form" class="upload-form">
                <input type="hidden" id="orderId" value={order.id} />
                
                <div class="file-input-wrapper">
                  <input type="file" id="paymentProof" accept="image/png, image/jpeg, image/jpg, application/pdf" required class="file-input" />
                </div>

                <button type="submit" id="submit-proof-btn" class="submit-btn">
                  SUBMIT PAYMENT PROOF
                </button>
              </form>
              <div id="upload-status" class="upload-status hidden"></div>
            </div>
          )}
        </div>

        <!-- Right: Order Summary -->
        <aside class="payment-sidebar">
          <div class="summary-card">
            <h2 class="sidebar-title sentient-heading">Order Summary</h2>
            <div class="order-id-badge">
              <span class="badge-label">Order ID</span>
              <span class="badge-value">{order.id}</span>
            </div>

            <div class="checkout-items-list">
              {order.items.map((item: any) => (
                <div class="summary-item">
                  <img src={item.image || '/assets/products/soe-bag-1.jpg'} alt={item.name} class="summary-item-image" />
                  <div class="summary-item-details">
                    <span class="summary-item-name">{item.name}</span>
                    <span class="summary-item-meta">Qty: {item.quantity}</span>
                  </div>
                  <span class="summary-item-price">IDR {(item.price * item.quantity).toLocaleString('id-ID').replace(/,/g, '.')}</span>
                </div>
              ))}
            </div>

            <div class="price-summary-lines">
              <div class="summary-line">
                <span class="line-label">Subtotal</span>
                <span class="line-value">IDR {order.subtotal.toLocaleString('id-ID').replace(/,/g, '.')}</span>
              </div>
              <div class="summary-line">
                <span class="line-label">Shipping Cost</span>
                <span class="line-value">IDR {order.shipping_cost.toLocaleString('id-ID').replace(/,/g, '.')}</span>
              </div>
              <div class="summary-line total-line">
                <span class="line-label">Total Amount</span>
                <span class="line-value">IDR {order.total_amount.toLocaleString('id-ID').replace(/,/g, '.')}</span>
              </div>
            </div>
          </div>
        </aside>
      </div>
    )}
  </div>
</Layout>

<style>
  .payment-wrapper {
    max-width: 1000px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem 2rem;
  }

  .sentient-heading {
    font-family: var(--font-serif);
    font-weight: 400;
  }

  .satoshi-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .error-state {
    text-align: center;
    padding: 8rem 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    align-items: center;
  }

  .back-link {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    text-decoration: underline;
    margin-top: 1rem;
  }

  .payment-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3.5rem;
    align-items: start;
  }

  @media (min-width: 992px) {
    .payment-grid {
      grid-template-columns: 1.2fr 1fr;
    }
  }

  .payment-title {
    font-size: var(--text-xl);
    letter-spacing: 0.05em;
    margin-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .bank-details-card {
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    padding: 2rem;
    text-align: center;
    margin-bottom: 3rem;
  }

  .bank-subtitle {
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-size: var(--text-xs);
  }

  .bank-name {
    font-family: var(--font-serif);
    font-size: var(--text-lg);
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .account-number {
    font-family: var(--font-sans);
    font-size: var(--text-xxl);
    font-weight: 700;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .account-name {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .upload-section {
    margin-bottom: 2rem;
  }

  .section-title {
    font-size: var(--text-lg);
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .upload-desc {
    margin-bottom: 1.5rem;
  }

  .upload-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .file-input-wrapper {
    border: 1px dashed var(--color-border);
    padding: 2rem;
    text-align: center;
    background-color: rgba(255, 255, 255, 0.01);
    transition: background-color 0.25s ease;
  }

  .file-input-wrapper:hover {
    background-color: rgba(255, 255, 255, 0.03);
  }

  .file-input {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-primary);
    width: 100%;
  }

  .submit-btn {
    background-color: var(--color-button-bg);
    color: var(--color-button-text);
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    border: none;
    cursor: pointer;
    transition: opacity 0.25s ease;
  }

  .submit-btn:hover {
    opacity: 0.9;
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .upload-status {
    margin-top: 1rem;
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    border: 1px solid var(--color-border);
    text-align: center;
  }

  .upload-status.hidden {
    display: none;
  }
  
  .upload-status.success {
    background-color: rgba(0, 255, 0, 0.05);
    border-color: rgba(0, 255, 0, 0.2);
    color: #4ade80;
  }

  .upload-status.error {
    background-color: rgba(255, 0, 0, 0.05);
    border-color: rgba(255, 0, 0, 0.2);
    color: #f87171;
  }

  .success-message {
    background-color: rgba(0, 255, 0, 0.05);
    border: 1px solid rgba(0, 255, 0, 0.2);
    padding: 2rem;
    text-align: center;
  }

  .success-message h3 {
    margin-bottom: 1rem;
    color: #4ade80;
  }

  /* Sidebar styling */
  .summary-card {
    background-color: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
  }

  .sidebar-title {
    font-size: var(--text-base);
    letter-spacing: 0.08em;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.65rem;
  }

  .order-id-badge {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: rgba(255, 255, 255, 0.05);
    padding: 0.75rem 1rem;
    margin-bottom: 1.5rem;
  }

  .badge-label {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-secondary);
  }

  .badge-value {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  /* Items List (reused from checkout) */
  .checkout-items-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1rem;
  }

  .summary-item {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .summary-item-image {
    width: 44px;
    height: 55px;
    object-fit: cover;
    background-color: #242424;
    border: 1px solid var(--color-border);
  }

  .summary-item-details {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .summary-item-name {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-primary);
  }

  .summary-item-meta {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
  }

  .summary-item-price {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-primary);
    margin-left: auto;
  }

  /* Price summary lines */
  .price-summary-lines {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .summary-line {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .summary-line.total-line {
    margin-top: 0.75rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.75rem;
    color: var(--color-text-primary);
    font-weight: 700;
    font-size: var(--text-base);
  }
</style>

<script>
  (function() {
    var form = document.getElementById('upload-form');
    if (!form) return;

    form.addEventListener('submit', function(e) {
      e.preventDefault();

      var orderId = document.getElementById('orderId').value;
      var fileInput = document.getElementById('paymentProof');
      var file = fileInput.files[0];
      var submitBtn = document.getElementById('submit-proof-btn');
      var statusEl = document.getElementById('upload-status');

      if (!file) return;

      submitBtn.disabled = true;
      submitBtn.textContent = 'UPLOADING...';
      statusEl.classList.add('hidden');

      // Create FormData to send the file to our API
      var formData = new FormData();
      formData.append('file', file);
      formData.append('orderId', orderId);

      fetch('/api/orders/upload-proof', {
        method: 'POST',
        body: formData
      })
      .then(function(res) {
        if (!res.ok) throw new Error('Upload failed');
        return res.json();
      })
      .then(function(data) {
        if (data.success) {
          statusEl.textContent = 'Payment proof uploaded successfully! We will review it shortly.';
          statusEl.className = 'upload-status success';
          submitBtn.textContent = 'UPLOADED';
          fileInput.disabled = true;
        } else {
          throw new Error(data.error || 'Unknown error');
        }
      })
      .catch(function(err) {
        statusEl.textContent = 'Error: ' + err.message;
        statusEl.className = 'upload-status error';
        submitBtn.disabled = false;
        submitBtn.textContent = 'SUBMIT PAYMENT PROOF';
      });
    });
  })();
</script>
