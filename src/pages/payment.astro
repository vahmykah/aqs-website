---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Secure Payment Terminal | A Quiet Space" noindex={true}>
  <div class="payment-wrapper">
    <div class="payment-container" id="payment-terminal-content">
      <!-- Loading State -->
      <div id="payment-loading" class="payment-loading">
        <div class="payment-indicator-ring">
          <span class="payment-indicator-dot"></span>
        </div>
        <h1 class="payment-title sentient-heading">LOADING GATEWAY...</h1>
      </div>

      <!-- Main Payment Gateway Simulator -->
      <div id="payment-gateway-main" class="payment-gateway-main hidden">
        <!-- Brand Title -->
        <h1 class="payment-title sentient-heading">A QUIET SPACE</h1>
        <p class="payment-subtitle satoshi-text">🔒 SECURE TRANSACTION SANDBOX</p>

        <!-- Order Information Box -->
        <div class="order-info-box">
          <div class="order-info-row">
            <span class="info-label satoshi-text">Order ID</span>
            <span class="info-value satoshi-text text-highlight" id="order-id-label">AQS-00000</span>
          </div>
          <div class="order-info-row">
            <span class="info-label satoshi-text">Customer</span>
            <span class="info-value satoshi-text" id="order-customer-label">John Doe</span>
          </div>
          <div class="order-info-row">
            <span class="info-label satoshi-text">Selected Method</span>
            <span class="info-value satoshi-text" id="order-method-label">QRIS</span>
          </div>
          <div class="order-info-row total-row">
            <span class="info-label satoshi-text">Total Payment</span>
            <span class="info-value satoshi-text text-highlight" id="order-total-label">IDR 0</span>
          </div>
        </div>

        <!-- Interactive Gateway Display -->
        <div class="payment-card">
          <h2 class="card-title sentient-heading" id="gateway-view-title">SIMULATED QRIS TERMINAL</h2>
          
          <!-- QRIS View -->
          <div id="view-qris" class="gateway-view">
            <div class="mock-qr-container">
              <!-- Inline QR Code SVG Mockup -->
              <svg class="mock-qr-svg" viewBox="0 0 100 100" width="160" height="160">
                <rect width="100" height="100" fill="#ffffff" />
                <path d="M5,5 h20 v20 h-20 z M5,12 h20 M12,5 v20 M10,10 h10 v10 h-10 z" fill="#111111" />
                <path d="M75,5 h20 v20 h-20 z M75,12 h20 M82,5 v20 M80,10 h10 v10 h-10 z" fill="#111111" />
                <path d="M5,75 h20 v20 h-20 z M5,82 h20 M12,75 v20 M10,80 h10 v10 h-10 z" fill="#111111" />
                <path d="M35,35 h30 v30 h-30 z" fill="#111111" opacity="0.1" />
                <rect x="40" y="40" width="20" height="20" fill="#111111" />
                <path d="M30,5 h10 v5 h-10 z M45,5 h20 v5 h-20 z M5,30 h5 v10 h-5 z M5,45 h5 v20 h-5 z M75,30 h10 v5 h-10 z M80,45 h15 v5 h-15 z" fill="#111111" />
                <path d="M30,85 h15 v10 h-15 z M50,80 h10 v5 h-10 z M65,85 h20 v10 h-20 z" fill="#111111" />
              </svg>
            </div>
            <p class="gateway-desc satoshi-text">
              Scan this QRIS code using your banking application (BCA, Mandiri, etc.) or E-Wallet (GoPay, OVO, Dana) to complete the checkout.
            </p>
          </div>

          <!-- Virtual Account View -->
          <div id="view-va" class="gateway-view hidden">
            <div class="va-number-box">
              <span class="va-label satoshi-text">BCA Virtual Account</span>
              <span class="va-code satoshi-text" id="va-code-display">89108 00000 00000</span>
              <button class="btn-copy-va satoshi-text" id="btn-copy-va">COPY NUMBER</button>
            </div>
            <p class="gateway-desc satoshi-text">
              Transfer funds from any banking application or ATM terminal to the Virtual Account number displayed above.
            </p>
          </div>

          <!-- E-Wallet View -->
          <div id="view-ewallet" class="gateway-view hidden">
            <div class="mock-ewallet-phone">
              <span class="ewallet-logo satoshi-text">GoPay Terminal</span>
              <div class="ewallet-phone-input">
                <span class="phone-prefix satoshi-text">+62</span>
                <span class="phone-val satoshi-text" id="ewallet-phone-display">812 3456 7890</span>
              </div>
            </div>
            <p class="gateway-desc satoshi-text">
              Open your GoPay/ShopeePay app notification to finalize transaction authorization.
            </p>
          </div>
        </div>

        <!-- Simulation Terminal controls (Developer Sandbox Panel) -->
        <div class="simulation-panel">
          <div class="sim-panel-header">
            <span class="sim-badge satoshi-text">DEVELOPER SANDBOX TERMINAL</span>
            <p class="sim-panel-desc satoshi-text">Simulate payment webhook callbacks to test order state transitions.</p>
          </div>
          <div class="payment-actions">
            <button type="button" id="btn-sim-success" class="btn-simulate-payment">
              ✓ SIMULATE SUCCESS (SETTLEMENT / PAID)
            </button>
            <button type="button" id="btn-sim-cancel" class="btn-simulate-cancel">
              ✗ SIMULATE EXPIRE / CANCEL (WEBHOOK)
            </button>
            <a href="/checkout" class="btn-return-checkout satoshi-text">← CANCEL & RETURN TO CHECKOUT</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .payment-wrapper {
    max-width: 800px;
    margin: 0 auto;
    padding: 5rem 2rem;
  }

  .sentient-heading {
    font-family: var(--font-serif);
    font-weight: 400;
  }

  .satoshi-text {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .payment-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Loading State */
  .payment-loading {
    padding: 8rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
  }

  .payment-indicator-ring {
    display: flex;
    justify-content: center;
    align-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--color-border);
    border-radius: 50%;
  }

  .payment-indicator-dot {
    display: block;
    width: 10px;
    height: 10px;
    background-color: var(--color-text-primary);
    border-radius: 50%;
    animation: pulse 2s infinite ease-in-out;
  }

  @keyframes pulse {
    0%, 100% {
      transform: scale(0.8);
      opacity: 0.5;
    }
    50% {
      transform: scale(1.2);
      opacity: 1;
    }
  }

  .payment-gateway-main {
    width: 100%;
    max-width: 520px;
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: fadeIn 0.4s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .payment-title {
    font-size: var(--text-lg);
    letter-spacing: 0.15em;
    margin-bottom: 0.25rem;
    color: var(--color-text-primary);
  }

  .payment-subtitle {
    font-size: var(--text-xxs);
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 2rem;
    opacity: 0.5;
  }

  /* Order Info Box */
  .order-info-box {
    width: 100%;
    background-color: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--color-border);
    padding: 1.25rem;
    margin-bottom: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    text-align: left;
  }

  .order-info-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .info-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.7;
  }

  .info-value {
    font-weight: 500;
    color: var(--color-text-primary);
  }

  .info-value.text-highlight {
    font-weight: 700;
  }

  .order-info-row.total-row {
    border-top: 1px dashed var(--color-border);
    padding-top: 0.75rem;
    margin-top: 0.25rem;
  }

  .total-row .info-label {
    font-weight: 700;
    opacity: 1;
    color: var(--color-text-primary);
  }

  .total-row .info-value {
    font-size: var(--text-base);
    color: var(--color-text-primary);
  }

  /* Payment Card */
  .payment-card {
    width: 100%;
    background-color: rgba(255, 255, 255, 0.01);
    border: 1px solid var(--color-border);
    padding: 2.25rem 1.75rem;
    margin-bottom: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
  }

  .card-title {
    font-size: var(--text-sm);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    border-bottom: 1px solid var(--color-border);
    width: 100%;
    padding-bottom: 0.75rem;
    margin: 0;
  }

  .gateway-view {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 100%;
    animation: fadeInView 0.3s ease;
  }

  @keyframes fadeInView {
    from { opacity: 0; }
    to { opacity: 1; }
  }

  .gateway-view.hidden {
    display: none;
  }

  .gateway-desc {
    font-size: var(--text-xs);
    line-height: 1.5;
    text-align: center;
    max-width: 380px;
    margin: 0;
  }

  /* QRIS Styles */
  .mock-qr-container {
    padding: 1rem;
    background-color: #ffffff;
    border: 4px solid var(--color-text-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
    display: flex;
    justify-content: center;
    align-items: center;
  }

  /* Virtual Account Styles */
  .va-number-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    padding: 1.25rem 2rem;
    width: 100%;
    box-sizing: border-box;
  }

  .va-label {
    font-size: var(--text-xxs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .va-code {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
    letter-spacing: 0.08em;
  }

  .btn-copy-va {
    background-color: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text-primary);
    padding: 0.35rem 0.75rem;
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .btn-copy-va:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: var(--color-text-primary);
  }

  /* E-Wallet Styles */
  .mock-ewallet-phone {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    border: 1px solid var(--color-border);
    background-color: rgba(255, 255, 255, 0.02);
    padding: 1.5rem;
    width: 100%;
    box-sizing: border-box;
  }

  .ewallet-logo {
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .ewallet-phone-input {
    display: flex;
    border-bottom: 2px solid var(--color-text-primary);
    padding-bottom: 0.5rem;
    gap: 0.5rem;
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .phone-prefix {
    opacity: 0.5;
  }

  /* Developer Panel */
  .simulation-panel {
    width: 100%;
    border: 1px solid var(--color-border);
    background-color: rgba(255, 0, 0, 0.02); /* Slight red hue signifying sandbox panel */
    padding: 1.5rem;
    text-align: left;
    box-sizing: border-box;
  }

  .sim-panel-header {
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .sim-badge {
    font-size: 0.7rem;
    font-weight: 700;
    color: #ffffff;
    letter-spacing: 0.1em;
    display: inline-block;
    padding: 0.15rem 0.4rem;
    border: 1px solid var(--color-border);
    background-color: rgba(255, 255, 255, 0.05);
    margin-bottom: 0.4rem;
  }

  .sim-panel-desc {
    font-size: var(--text-xs);
    opacity: 0.7;
    margin: 0;
    line-height: 1.4;
  }

  .payment-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
  }

  .btn-simulate-payment {
    width: 100%;
    background-color: #ffffff;
    color: #000000;
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-align: center;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .btn-simulate-payment:hover {
    opacity: 0.9;
  }

  .btn-simulate-cancel {
    width: 100%;
    background-color: transparent;
    color: var(--color-text-primary);
    border: 1px solid var(--color-border);
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-align: center;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease;
  }

  .btn-simulate-cancel:hover {
    background-color: rgba(255, 255, 255, 0.05);
    border-color: var(--color-text-primary);
  }

  .btn-return-checkout {
    display: block;
    text-align: center;
    font-size: var(--text-xxs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-top: 0.5rem;
    transition: color 0.2s ease;
  }

  .btn-return-checkout:hover {
    color: var(--color-text-primary);
  }

  .hidden {
    display: none !important;
  }
</style>

<script is:inline>
  (function() {
    var loadingEl = document.getElementById('payment-loading');
    var mainEl = document.getElementById('payment-gateway-main');

    var orderIdLabel = document.getElementById('order-id-label');
    var customerLabel = document.getElementById('order-customer-label');
    var methodLabel = document.getElementById('order-method-label');
    var totalLabel = document.getElementById('order-total-label');

    var viewTitle = document.getElementById('gateway-view-title');
    var qrisView = document.getElementById('view-qris');
    var vaView = document.getElementById('view-va');
    var ewalletView = document.getElementById('view-ewallet');

    var vaCodeDisplay = document.getElementById('va-code-display');
    var ewalletPhoneDisplay = document.getElementById('ewallet-phone-display');

    var btnCopyVa = document.getElementById('btn-copy-va');
    var btnSimSuccess = document.getElementById('btn-sim-success');
    var btnSimCancel = document.getElementById('btn-sim-cancel');

    var currentOrder = null;

    function formatIDR(amount) {
      return 'IDR ' + amount.toLocaleString('id-ID').replace(/,/g, '.');
    }

    // 1. Fetch pending order details from storage
    function loadOrder() {
      var stored = localStorage.getItem('aqs_pending_order');
      if (!stored) {
        // No order to pay, send back
        alert('No pending order found. Returning to homepage.');
        window.location.href = '/';
        return;
      }

      try {
        currentOrder = JSON.parse(stored);
      } catch (e) {
        alert('Invalid order data.');
        window.location.href = '/';
        return;
      }

      // Populate labels
      if (orderIdLabel) orderIdLabel.textContent = currentOrder.orderId;
      if (customerLabel) customerLabel.textContent = currentOrder.customer.name;
      if (methodLabel) methodLabel.textContent = currentOrder.paymentMethod;
      if (totalLabel) totalLabel.textContent = formatIDR(currentOrder.orderTotal);

      // Render correct gateway view based on payment method
      var method = currentOrder.paymentMethod;
      if (method === 'QRIS') {
        if (viewTitle) viewTitle.textContent = 'SIMULATED QRIS TERMINAL';
        if (qrisView) qrisView.classList.remove('hidden');
      } else if (method === 'Virtual Account') {
        if (viewTitle) viewTitle.textContent = 'SIMULATED VIRTUAL ACCOUNT';
        if (vaView) vaView.classList.remove('hidden');
        if (vaCodeDisplay) {
          // Generate realistic BCA virtual account code
          var randNumber = Math.floor(1000000000 + Math.random() * 9000000000);
          vaCodeDisplay.textContent = '89108 ' + String(randNumber).substring(0, 5) + ' ' + String(randNumber).substring(5);
        }
      } else {
        // E-Wallet
        if (viewTitle) viewTitle.textContent = 'SIMULATED E-WALLET TERMINAL';
        if (ewalletView) ewalletView.classList.remove('hidden');
        if (ewalletPhoneDisplay) ewalletPhoneDisplay.textContent = currentOrder.customer.phone;
      }

      // Show main gateway, hide loading
      setTimeout(function() {
        if (loadingEl) loadingEl.classList.add('hidden');
        if (mainEl) mainEl.classList.remove('hidden');
      }, 800);
    }

    // Copy VA handler
    if (btnCopyVa) {
      btnCopyVa.addEventListener('click', function() {
        var code = vaCodeDisplay.textContent;
        navigator.clipboard.writeText(code).then(function() {
          btnCopyVa.textContent = 'COPIED!';
          setTimeout(function() {
            btnCopyVa.textContent = 'COPY NUMBER';
          }, 2000);
        });
      });
    }

    // Success simulation webhook callback
    if (btnSimSuccess) {
      btnSimSuccess.addEventListener('click', function() {
        if (!currentOrder) return;

        var now = new Date().toISOString();
        
        // Update paymentStatus to Paid
        currentOrder.paymentStatus = 'Paid';
        
        // Push to statusHistory
        currentOrder.statusHistory.push({
          status: 'Paid',
          timestamp: now,
          note: 'Payment successfully settled via ' + currentOrder.paymentMethod + ' (Simulator Webhook).'
        });

        // Add payment metadata
        currentOrder.paymentMetadata = {
          transactionId: 'midtrans-tx-' + Math.floor(100000 + Math.random() * 900000),
          paymentType: currentOrder.paymentMethod.toLowerCase().replace(/\s/g, '_'),
          vaNumber: currentOrder.paymentMethod === 'Virtual Account' ? vaCodeDisplay.textContent : undefined,
          settlementTime: now,
          fraudStatus: 'accept'
        };

        currentOrder.updatedAt = now;

        // Save order back
        localStorage.setItem('aqs_pending_order', JSON.stringify(currentOrder));

        console.log('[Email Queue System Trigger] Queuing ORDER_CONFIRMED receipt email for Paid status.');

        // Redirect to success page
        window.location.href = '/order-success';
      });
    }

    // Cancel/Expire simulation callback
    if (btnSimCancel) {
      btnSimCancel.addEventListener('click', function() {
        if (!currentOrder) return;

        var now = new Date().toISOString();

        // Update paymentStatus to Cancelled
        currentOrder.paymentStatus = 'Cancelled';

        // Push to statusHistory
        currentOrder.statusHistory.push({
          status: 'Cancelled',
          timestamp: now,
          note: 'Transaction expired or cancelled by customer at payment terminal (Simulator Webhook).'
        });

        currentOrder.updatedAt = now;

        // Save order back
        localStorage.setItem('aqs_pending_order', JSON.stringify(currentOrder));

        console.log('[Email Queue System Trigger] Queuing ORDER_CANCELLED receipt email for Cancelled status.');

        // Redirect to success page (which displays cancelled state details)
        window.location.href = '/order-success';
      });
    }

    // Load order on mount
    loadOrder();
  })();
</script>
