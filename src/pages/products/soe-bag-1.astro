    src: "/images/front.jpg",
    captionTitle: "FRONT VIEW",
    captionDesc: "The State of Enough."
  },
  { 
    label: "02. Tote Carry", 
    src: "/images/tote.jpg",
    captionTitle: "TOTE BAG MODE",
    captionDesc: "Designed for everyday ease."
  },
  { 
    label: "03. Sling Carry", 
    src: "/images/sling.jpg",
    captionTitle: "SLING BAG MODE",
    captionDesc: "One of three carry configurations."
  },
  { 
    label: "04. Backpack Carry", 
    src: "/images/backpack.jpg",
    captionTitle: "BACKPACK MODE",
    captionDesc: "Hands-free versatility."
  },
  { 
    label: "05. Laptop Compartment", 
    src: "/images/laptop.jpg",
    captionTitle: "LAPTOP COMPARTMENT",
    captionDesc: "Dedicated storage for daily essentials."
  },
  { 
    label: "06. Bottle Holder", 
    src: "/images/bottle.jpg",
    captionTitle: "BOTTLE HOLDER",
    captionDesc: "Keeps hydration within reach."
  },
  { 
    label: "07. Large Zipper Pocket", 
    src: "/images/zipper.jpg",
    captionTitle: "LARGE ZIPPER POCKET",
    captionDesc: "Secure storage for essentials."
  },
  { 
    label: "08. Utility Pockets", 
    src: "/images/texture.jpg",
    captionTitle: "UTILITY POCKETS",
    captionDesc: "Organized access to smaller items."
  },
  { 
    label: "09. Premium Nylon Straps", 
    src: "/images/straps.jpg",
    captionTitle: "PREMIUM NYLON STRAPS",
    captionDesc: "Tactile strength and durability."
  },
  { 
    label: "10. High Density Arabic Typography", 
    src: "/images/hero-editorial.jpg",
    captionTitle: "HIGH DENSITY ARABIC TYPOGRAPHY",
    captionDesc: "A visual reminder inspired by timeless wisdom."
  },
  { 
    label: "11. Premium Canvas Construction", 
    src: "/images/construction.jpg",
    captionTitle: "PREMIUM CANVAS CONSTRUCTION",
    captionDesc: "Built to endure, designed to remain."
  }
];

const bag1PriceNumeric = 305000;
---

<Layout 
  title="SOE Bag 1 | A Quiet Space" 
  description="Explore the SOE Bag 1 details. A 3-way carry system bag with dedicated laptop compartments, interior organization, and canvas construction."
>
  <!-- 1. Three-Column Interactive Gallery -->
  <FeatureGallery items={bag1Features}>
    <!-- Column 3: Product Purchasing Details -->
    <div class="product-purchase-details">
      <div class="stock-status-wrap">
        <span class="stock-status">IN STOCK</span>
        <span class="stock-count">47 AVAILABLE</span>
      </div>
      <h1 class="product-title">SOE Bag 1</h1>
      <span class="product-price">IDR 305.000</span>
      
      <!-- Quantity Selector -->
      <div class="quantity-selector-container">
        <span class="selector-label">QUANTITY</span>
        <div class="quantity-selector">
          <button type="button" class="qty-btn dec-btn" id="qty-dec-btn" aria-label="Decrease quantity">−</button>
          <span class="qty-val" id="qty-val-display">1</span>
          <button type="button" class="qty-btn inc-btn" id="qty-inc-btn" aria-label="Increase quantity">+</button>
        </div>
      </div>

      <div class="purchase-actions">
        <button 
          id="detail-add-to-cart-btn" 
          class="add-to-cart-btn"
          data-product-id="soe-bag-1"
          data-product-name="SOE Bag 1"
          data-product-price={bag1PriceNumeric}
        >
          ADD TO CART
        </button>
        <button 
          id="detail-buy-it-now-btn" 
          class="buy-it-now-btn"
        >
          BUY IT NOW
        </button>
      </div>

      <!-- Short Product Description: Styled in Sentient (Serif) for Editorial Character -->
      <p class="product-short-description">
        SOE Bag 1 is crafted from premium canvas and finished with high-density Arabic typography, creating a quiet balance between function and meaning.<br /><br />
        Designed with a versatile three-way carry system, dedicated organization compartments, and included premium nylon straps, it adapts to different ways of carrying throughout the day.<br /><br />
        More than an everyday bag, it serves as a subtle reminder of the values we choose to carry—bringing utility, reflection, and identity into one understated object.
      </p>

    </div>
  </FeatureGallery>


