            <a href="/products/soe-bag-2" class="rec-card-link">
              <img src="/images/bag-2-front.jpg" alt="SOE Bag 2" class="rec-card-img" />
              <div class="rec-card-overlay">
                <span class="view-details-btn">VIEW DETAILS →</span>
              </div>
            </a>
          </div>
          <div class="rec-card-meta">
            <span class="rec-card-title">SOE Bag 2</span>
            <span class="rec-card-price">IDR 285.000</span>
          </div>
        </div>

        <!-- Card 2: SOE Bag 3 -->
        <div class="bottom-rec-card">
          <div class="rec-image-wrapper">
            <a href="/products/soe-bag-2" class="rec-card-link">
              <img src="/images/teaser.jpg" alt="SOE Bag 3" class="rec-card-img" />
              <div class="rec-card-overlay">
                <span class="view-details-btn">VIEW DETAILS →</span>
              </div>
            </a>
          </div>
          <div class="rec-card-meta">
            <span class="rec-card-title">SOE Bag 3</span>
            <span class="rec-card-price">IDR [Price]</span>
          </div>
        </div>

        <!-- Card 3: SOE Bag 4 -->
        <div class="bottom-rec-card">
          <div class="rec-image-wrapper">
            <a href="/products/soe-bag-1" class="rec-card-link">
              <img src="/images/construction.jpg" alt="SOE Bag 4" class="rec-card-img" />
              <div class="rec-card-overlay">
                <span class="view-details-btn">VIEW DETAILS →</span>
              </div>
            </a>
          </div>
          <div class="rec-card-meta">
            <span class="rec-card-title">SOE Bag 4</span>
            <span class="rec-card-price">IDR [Price]</span>
          </div>
        </div>

        <!-- Card 4: SOE Bag 5 -->
        <div class="bottom-rec-card">
          <div class="rec-image-wrapper">
            <a href="/products/soe-bag-1" class="rec-card-link">
              <img src="/images/texture.jpg" alt="SOE Bag 5" class="rec-card-img" />
              <div class="rec-card-overlay">
                <span class="view-details-btn">VIEW DETAILS →</span>
              </div>
            </a>
          </div>
          <div class="rec-card-meta">
