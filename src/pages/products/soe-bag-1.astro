</Layout>

<style>
  /* Purchasing Details Column (Satoshi typography, Monochrome, Minimalist) */
  .product-purchase-details {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    text-align: left;
    width: 100%;
    padding-top: 0.5rem;
  }

  .stock-status-wrap {
    display: flex;
    gap: 0.75rem;
    align-items: center;
    margin-bottom: 0.75rem;
  }

  .stock-status {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.25em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }

  .stock-count {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: #ffffff;
    letter-spacing: 0.05em;
  }

  .product-title {
    font-family: var(--font-sans);
    font-size: var(--text-xl);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-primary);
    margin: 0;
    line-height: 1.1;
  }

  .product-price {
    font-family: var(--font-sans);
    font-size: var(--text-base);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-text-primary);
    margin-top: 0.5rem;
    display: block;
  }

  /* Quantity Selector Styling */
  .quantity-selector-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-top: 2rem;
    width: 100%;
  }

  .selector-label {
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-secondary);
  }

  .quantity-selector {
    display: flex;
    align-items: center;
    border: 1px solid var(--color-border);
    width: fit-content;
    background-color: transparent;
  }

  .qty-btn {
    background: transparent;
    border: none;
    color: #ffffff;
    width: 40px;
    height: 40px;
    font-family: var(--font-sans);
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    justify-content: center;
    align-items: center;
    transition: background-color 0.2s;
  }

  .qty-btn:hover {
    background-color: rgba(255, 255, 255, 0.1);
  }

  .qty-val {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    color: #ffffff;
    width: 40px;
    text-align: center;
  }

  .purchase-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    width: 100%;
    margin: 2.5rem 0;
  }

  .add-to-cart-btn {
    background-color: var(--color-button-bg);
    color: var(--color-button-text);
    padding: 1.15rem 4rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    transition: opacity 0.2s ease;
    border-radius: 0;
    width: 100%;
    border: 1px solid var(--color-button-bg);
    cursor: pointer;
  }

  .add-to-cart-btn:hover {
    opacity: 0.9;
  }

  .buy-it-now-btn {
    background-color: transparent;
    color: #ffffff;
    border: 1px solid #ffffff;
    padding: 1.15rem 4rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    transition: background-color 0.2s ease, color 0.2s ease;
    border-radius: 0;
    width: 100%;
    cursor: pointer;
  }

  .buy-it-now-btn:hover {
    background-color: #ffffff;
    color: #000000;
  }

  .product-short-description {
    font-family: var(--font-serif);
    font-size: var(--text-sm);
    line-height: 1.8;
    color: var(--color-text-secondary);
    letter-spacing: 0.01em;
    text-align: justify;
    margin: 0;
  }



  /* Bottom Recommendations Section styles */
  .bottom-recommendations-section {
    padding: var(--spacing-xl) 0;
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .bottom-rec-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
  }

  .bottom-rec-title {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .bottom-rec-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr); /* 4 cards horizontally on desktop */
    gap: 2rem;
  }

  .bottom-rec-card {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    text-align: center;
  }

  .rec-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    background-color: #242424;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .rec-card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .rec-card-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .rec-card-link:hover .rec-card-img {
    transform: scale(1.03); /* Slight zoom on hover */
  }

  .rec-card-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.2);
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .rec-card-link:hover .rec-card-overlay {
    opacity: 1;
  }

  .view-details-btn {
    background-color: var(--color-button-bg); /* White */
    color: var(--color-button-text); /* Black */
    padding: 0.75rem 1.5rem;
    font-family: var(--font-sans);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    border-radius: 0;
  }

  .rec-card-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
  }

  .rec-card-title {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .rec-card-price {
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 500;
    color: var(--color-text-secondary);
  }

  @media (max-width: 1024px) {
    .bottom-rec-grid {
      grid-template-columns: repeat(2, 1fr); /* 2 columns on tablets */
      gap: 1.5rem;
    }
  }

  @media (max-width: 767px) {

    .bottom-recommendations-section {
      padding: var(--spacing-lg) 0;
    }

    .bottom-rec-grid {
      grid-template-columns: 1fr; /* Stack vertically on mobile */
      gap: 2rem;
    }
  }
</style>

<script>
  const addBtn = document.getElementById('detail-add-to-cart-btn');
  const buyBtn = document.getElementById('detail-buy-it-now-btn');
  const decBtn = document.getElementById('qty-dec-btn');
  const incBtn = document.getElementById('qty-inc-btn');
  const qtyValDisplay = document.getElementById('qty-val-display');

  let currentQty = 1;

  if (decBtn && qtyValDisplay) {
    decBtn.addEventListener('click', () => {
      if (currentQty > 1) {
        currentQty--;
        qtyValDisplay.textContent = currentQty.toString();
      }
    });
  }

  if (incBtn && qtyValDisplay) {
    incBtn.addEventListener('click', () => {
      currentQty++;
      qtyValDisplay.textContent = currentQty.toString();
    });
  }

  if (addBtn) {
    addBtn.addEventListener('click', () => {
      if ((window as any).AQS_Cart) {
        (window as any).AQS_Cart.addItem({
          id: 'soe-bag-1',
          name: 'SOE Bag 1',
          price: 305000,
          image: '/images/front.jpg'
        }, currentQty);
      }
    });
  }

  if (buyBtn) {
    buyBtn.addEventListener('click', () => {
      if ((window as any).AQS_Cart) {
        (window as any).AQS_Cart.addItem({
          id: 'soe-bag-1',
          name: 'SOE Bag 1',
          price: 305000,
          image: '/images/front.jpg'
        }, currentQty);
        setTimeout(() => {
          const checkoutBtn = document.getElementById('cart-checkout-button');
          if (checkoutBtn) {
            checkoutBtn.click();
          }
        }, 150);
      }
    });
  }
</script>
