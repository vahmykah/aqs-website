---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
---

<Layout hideHeader={true}>
  <!-- 1. Fullscreen Brand Banner (Header removed entirely) -->
  <Hero 
    desktopSrc="/images/hero-desktop.jpg" 
    mobileSrc="/images/hero-desktop.jpg" 
    alt="A Quiet Space Brand Banner" 
  />


  <!-- 2. Vertical Collection Entries Section -->
  <section class="collection-section">
    <div class="collection-container">
      
      <!-- Entry 01: SOE Bag 1 -->
      <article class="collection-entry">
        <span class="entry-number">ARTICLE 01 — THE STATE OF ENOUGH</span>
        <div class="entry-image-wrapper">
          <a href="/products/soe-bag-1" class="entry-link" aria-label="View SOE Bag 1 Details">
            <img src="/images/front.jpg" alt="SOE Bag 1" class="entry-img" loading="lazy" />
            <div class="entry-overlay">
              <span class="view-details-btn">VIEW DETAILS →</span>
            </div>
          </a>
        </div>
        <div class="entry-meta">
          <h2 class="entry-title">SOE Bag 1</h2>
          <span class="entry-price">IDR 305.000</span>
        </div>
      </article>

      <!-- Entry 02: SOE Bag 2 -->
      <article class="collection-entry">
        <span class="entry-number">ARTICLE 01 — THE STATE OF ENOUGH</span>
        <div class="entry-image-wrapper">
          <a href="/products/soe-bag-2" class="entry-link" aria-label="View SOE Bag 2 Details">
            <img src="/images/bag-2-front.jpg" alt="SOE Bag 2" class="entry-img" loading="lazy" />
            <div class="entry-overlay">
              <span class="view-details-btn">VIEW DETAILS →</span>
            </div>
          </a>
        </div>
        <div class="entry-meta">
          <h2 class="entry-title">SOE Bag 2</h2>
          <span class="entry-price">IDR 285.000</span>
        </div>
      </article>

    </div>
  </section>
</Layout>

<style>
  .collection-section {
    padding: var(--spacing-lg) 0;
    background-color: var(--color-bg);
    border-top: 1px solid var(--color-border);
  }

  .collection-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--spacing-md);
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg); /* Generous spacing between vertical entries */
    align-items: center;
  }

  .collection-entry {
    width: 100%;
    max-width: 600px; /* Elegant, focused width matching product viewport proportions */
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
    text-align: center;
  }

  .entry-number {
    font-family: var(--font-sans); /* Satoshi */
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.25em;
    color: var(--color-text-secondary);
    text-transform: uppercase;
  }

  .entry-image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5; /* Matches the gallery aspect ratio */
    background-color: #242424;
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .entry-link {
    display: block;
    width: 100%;
    height: 100%;
  }

  .entry-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .entry-link:hover .entry-img {
    transform: scale(1.02); /* Smooth zoom-in on hover */
  }

  .entry-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.15); /* Subtle dark overlay */
    display: flex;
    justify-content: center;
    align-items: center;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .entry-link:hover .entry-overlay {
    opacity: 1;
  }

  .view-details-btn {
    background-color: var(--color-button-bg); /* Solid white */
    color: var(--color-button-text); /* Solid dark */
    padding: 1rem 2.5rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.15em;
    border-radius: 0;
  }

  .entry-meta {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.35rem;
  }

  .entry-title {
    font-family: var(--font-sans);
    font-size: var(--text-lg);
    font-weight: 700;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-text-primary);
  }

  .entry-price {
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-text-secondary);
  }

  @media (max-width: 767px) {
    .collection-section {
      padding: var(--spacing-md) 0;
    }

    .collection-container {
      gap: var(--spacing-md);
    }

    .entry-overlay {
      display: none;
    }
  }
</style>
