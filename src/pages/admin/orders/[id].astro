---
import Layout from '../../../layouts/Layout.astro';
import { supabase } from '../../../lib/supabase';

export const prerender = false;

// Check Auth
const authCookie = Astro.cookies.get('admin_auth');
if (!authCookie || authCookie.value !== 'authenticated') {
  return Astro.redirect('/admin/login');
}

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/admin/orders');
}

const { data: order, error } = await supabase
  .from('orders')
  .select('*')
  .eq('id', id)
  .single();

if (error || !order) {
  return Astro.redirect('/admin/orders');
}
---

<Layout title={`Order ${order.id} | Admin`} noindex={true}>
  <div class="admin-wrapper">
    <div class="admin-header">
      <div>
        <a href="/admin/orders" class="back-link">← Back to Orders</a>
        <h1 class="sentient-heading">Order {order.id}</h1>
      </div>
      <div class="status-badges">
        <span class={`status-badge ${order.payment_status === 'Paid' ? 'success' : 'warning'}`}>
          {order.payment_status}
        </span>
        <span class={`status-badge ${order.fulfillment_status === 'Shipped' ? 'success' : 'neutral'}`}>
          {order.fulfillment_status}
        </span>
      </div>
    </div>

    <div class="content-grid">
      <!-- Left Column: Details -->
      <div class="main-col">
        <section class="admin-section">
          <h2>Customer Details</h2>
          <div class="detail-grid">
            <div class="detail-item">
              <span class="detail-label">Name</span>
              <span class="detail-value">{order.customer_name}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Email</span>
              <span class="detail-value">{order.customer_email}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Phone</span>
              <span class="detail-value">{order.customer_phone}</span>
            </div>
          </div>
        </section>

        <section class="admin-section">
          <h2>Shipping Address</h2>
          <div class="detail-grid">
            <div class="detail-item">
              <span class="detail-label">Province</span>
              <span class="detail-value">{order.shipping_province}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">City</span>
              <span class="detail-value">{order.shipping_city}</span>
            </div>
            <div class="detail-item">
              <span class="detail-label">Postal Code</span>
              <span class="detail-value">{order.shipping_postal_code}</span>
            </div>
            <div class="detail-item full-width">
              <span class="detail-label">Full Address</span>
              <span class="detail-value">{order.shipping_address}</span>
            </div>
          </div>
        </section>

        <section class="admin-section">
          <h2>Order Items</h2>
          <div class="items-list">
            {order.items && order.items.map((item: any) => (
              <div class="item-row">
                <span>{item.quantity}x {item.name}</span>
                <span>IDR {(item.price * item.quantity).toLocaleString('id-ID')}</span>
              </div>
            ))}
          </div>
          <div class="totals">
            <div class="total-row">
              <span>Subtotal</span>
              <span>IDR {order.subtotal.toLocaleString('id-ID')}</span>
            </div>
            <div class="total-row">
              <span>Shipping ({order.shipping_method})</span>
              <span>IDR {order.shipping_cost.toLocaleString('id-ID')}</span>
            </div>
            <div class="total-row grand-total">
              <span>Total</span>
              <span>IDR {order.total_amount.toLocaleString('id-ID')}</span>
            </div>
          </div>
        </section>
      </div>

      <!-- Right Column: Actions & Proof -->
      <div class="sidebar-col">
        <section class="admin-section action-section">
          <h2>Payment Proof</h2>
          {order.payment_proof_url ? (
            <div class="proof-container">
              <a href={order.payment_proof_url} target="_blank" rel="noopener noreferrer">
                <img src={order.payment_proof_url} alt="Payment Proof" class="proof-image" />
              </a>
              <p class="text-xs text-secondary mt-2">Click image to open in new tab</p>
            </div>
          ) : (
            <p class="text-secondary">No payment proof uploaded yet.</p>
          )}
        </section>

        <section class="admin-section action-section">
          <h2>Admin Actions</h2>
          
          <div id="action-status" class="action-status hidden"></div>

          {order.payment_status !== 'Paid' && (
            <div class="action-box">
              <p class="action-desc">Confirm that you have received the payment.</p>
              <button class="btn btn-success" onclick={`updateStatus('PAID', '${order.id}')`}>
                MARK AS PAID
              </button>
            </div>
          )}

          {order.payment_status === 'Paid' && order.fulfillment_status !== 'Shipped' && (
            <div class="action-box">
              <p class="action-desc">Provide tracking details to mark as shipped.</p>
              <input type="text" id="courierName" placeholder="Courier Name (e.g. JNE)" class="admin-input" />
              <input type="text" id="trackingNumber" placeholder="Tracking Number (Resi)" class="admin-input" />
              <button class="btn btn-primary" onclick={`updateStatus('SHIPPED', '${order.id}')`}>
                MARK AS SHIPPED
              </button>
            </div>
          )}

          {order.fulfillment_status === 'Shipped' && (
            <div class="action-box success-box">
              <p><strong>Courier:</strong> {order.courier_name}</p>
              <p><strong>Tracking:</strong> {order.tracking_number}</p>
            </div>
          )}
        </section>
      </div>
    </div>
  </div>
</Layout>

<style>
  .admin-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3rem 2rem 6rem 2rem;
    font-family: var(--font-sans);
  }

  .admin-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 3rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 1.5rem;
  }

  .back-link {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
    text-decoration: none;
    margin-bottom: 1rem;
    display: inline-block;
  }

  .back-link:hover {
    color: var(--color-text-primary);
  }

  .sentient-heading {
    font-family: var(--font-serif);
    font-size: var(--text-xl);
    letter-spacing: 0.05em;
    margin: 0;
  }

  .status-badges {
    display: flex;
    gap: 0.5rem;
  }

  .status-badge {
    padding: 0.4rem 0.8rem;
    border-radius: 4px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .status-badge.success {
    background-color: rgba(0, 255, 0, 0.1);
    color: #4ade80;
  }

  .status-badge.warning {
    background-color: rgba(250, 173, 20, 0.1);
    color: #faad14;
  }

  .status-badge.neutral {
    background-color: rgba(255, 255, 255, 0.1);
    color: var(--color-text-primary);
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 992px) {
    .content-grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  .admin-section {
    margin-bottom: 3rem;
  }

  .admin-section h2 {
    font-size: var(--text-base);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    padding-bottom: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .detail-item.full-width {
    grid-column: span 2;
  }

  .detail-label {
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
  }

  .detail-value {
    font-size: var(--text-sm);
    color: var(--color-text-primary);
  }

  .items-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .item-row {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-sm);
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .totals {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .total-row {
    display: flex;
    justify-content: space-between;
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
  }

  .grand-total {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .action-section {
    background-color: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--color-border);
    padding: 1.5rem;
  }

  .action-section h2 {
    margin-top: 0;
  }

  .proof-image {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
  }

  .action-box {
    margin-bottom: 1.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .action-box:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .action-desc {
    font-size: var(--text-xs);
    color: var(--color-text-secondary);
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .admin-input {
    width: 100%;
    background-color: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--color-border);
    color: white;
    padding: 0.75rem;
    margin-bottom: 0.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
  }

  .btn {
    width: 100%;
    padding: 1rem;
    font-family: var(--font-sans);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    border: none;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .btn:hover {
    opacity: 0.9;
  }

  .btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .btn-success {
    background-color: #4ade80;
    color: #000;
  }

  .btn-primary {
    background-color: var(--color-text-primary);
    color: #000;
  }

  .action-status {
    padding: 1rem;
    margin-bottom: 1.5rem;
    font-size: var(--text-sm);
    text-align: center;
  }

  .action-status.hidden {
    display: none;
  }

  .action-status.success {
    background-color: rgba(0, 255, 0, 0.1);
    color: #4ade80;
    border: 1px solid rgba(0, 255, 0, 0.2);
  }

  .action-status.error {
    background-color: rgba(255, 0, 0, 0.1);
    color: #f87171;
    border: 1px solid rgba(255, 0, 0, 0.2);
  }

  .text-secondary { color: var(--color-text-secondary); }
  .text-xs { font-size: var(--text-xs); }
  .mt-2 { margin-top: 0.5rem; }
</style>

<script is:inline>
  function updateStatus(action, orderId) {
    var statusEl = document.getElementById('action-status');
    statusEl.classList.remove('hidden', 'success', 'error');
    statusEl.textContent = 'Processing...';

    var payload = { action: action, orderId: orderId };

    if (action === 'SHIPPED') {
      var courier = document.getElementById('courierName').value;
      var tracking = document.getElementById('trackingNumber').value;
      if (!courier || !tracking) {
        statusEl.textContent = 'Please enter both Courier and Tracking Number.';
        statusEl.classList.add('error');
        return;
      }
      payload.courier = courier;
      payload.tracking = tracking;
    }

    fetch('/api/admin/orders/status', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload)
    })
    .then(function(res) {
      if (!res.ok) throw new Error('API Error');
      return res.json();
    })
    .then(function(data) {
      if (data.success) {
        statusEl.textContent = 'Success! Reloading...';
        statusEl.classList.add('success');
        setTimeout(function() { window.location.reload(); }, 1000);
      } else {
        throw new Error(data.error || 'Unknown error');
      }
    })
    .catch(function(err) {
      statusEl.textContent = 'Failed to update order: ' + err.message;
      statusEl.classList.add('error');
    });
  }
</script>
