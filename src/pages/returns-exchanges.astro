---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Return & Exchange Policy | A Quiet Space" description="Read about A Quiet Space's return and exchange eligibility criteria, process instructions, and shipping fee terms.">
  <div class="about-wrapper">
    <header class="about-header">
      <h1 class="brand-title sentient-heading">A Quiet Space</h1>
      <span class="brand-tagline satoshi-text">carry what matters</span>
    </header>

    <div class="about-content">
      <section class="about-section">
        <h2 class="section-title sentient-heading">Return & Exchange Policy</h2>
        <ul class="policy-list">
          <li class="about-text">Returns or exchanges can be requested within 7 days of receiving the order.</li>
          <li class="about-text">Items must be unused, unwashed, and in original condition with all tags and accessories included.</li>
          <li class="about-text">Products damaged through misuse are not eligible for return or exchange.</li>
          <li class="about-text">Customers should contact A Quiet Space through the official contact channel before sending any item back.</li>
          <li class="about-text">Shipping fees for returns are the responsibility of the customer unless the item received is defective or incorrect.</li>
          <li class="about-text">Approved exchanges are subject to stock availability.</li>
        </ul>
      </section>
    </div>
  </div>
</Layout>

<style>
  .about-wrapper {
    max-width: 720px;
    margin: 0 auto;
    padding: 6rem 2rem 8rem 2rem;
  }

  .about-header {
    text-align: center;
    margin-bottom: 5rem;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 2.5rem;
  }

  .sentient-heading {
    font-family: var(--font-serif);
    font-weight: 400;
  }

  .satoshi-text {
    font-family: var(--font-sans);
  }

  .brand-title {
    font-size: var(--text-xxl);
    letter-spacing: 0.1em;
    margin-bottom: 0.75rem;
    text-transform: uppercase;
  }

  .brand-tagline {
    font-size: var(--text-sm);
    letter-spacing: 0.25em;
    text-transform: lowercase;
    color: var(--color-text-secondary);
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: 4.5rem;
  }

  .about-section {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .section-title {
    font-size: var(--text-lg);
    letter-spacing: 0.05em;
    color: var(--color-text-primary);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 0.75rem;
    margin-bottom: 1rem;
  }

  .policy-list {
    list-style: none;
    padding-left: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .policy-list li {
    position: relative;
    padding-left: 1.75rem;
    font-family: var(--font-sans);
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--color-text-secondary);
    text-align: justify;
  }

  .policy-list li::before {
    content: "—";
    position: absolute;
    left: 0;
    color: var(--color-text-secondary);
  }

  @media (max-width: 767px) {
    .about-wrapper {
      padding: 4rem 1.25rem 6rem 1.25rem;
    }

    .about-header {
      margin-bottom: 3.5rem;
      padding-bottom: 2rem;
    }

    .section-title {
      font-size: var(--text-base);
    }

    .policy-list li {
      text-align: left;
    }
  }
</style>
